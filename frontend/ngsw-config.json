{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|jpg|jpeg|png)"
        ]
      }
    },
    {
      "name": "i18n",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/i18n/*.json"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-products",
      "urls": [
        "http://127.0.0.1:8000/api/products",
        "http://127.0.0.1:8000/api/products/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "1d",
        "timeout": "10s"
      }
    },
    {
      "name": "api-images",
      "urls": [
        "http://localhost:8000/storage/products/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 100,
        "maxAge": "7d",
        "timeout": "10s",
        "cacheOpaqueResponses": true
      }
    }
  ]
}